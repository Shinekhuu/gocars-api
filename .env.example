MODE=PRODUCTION

# PostgreSQL
PG_HOST=
PG_PORT=5432
PG_NAME=postgres
PG_USER=
PG_PASSWORD=
PG_SSL_MODE=require

# Redis
REDIS_ADDR=http://localhost:6379
REDIS_PASSWORD=

# Meilisearch (docker service)
MEILI_URL=http://meilisearch:7700
MEILI_MASTER_KEY=

# Service-to-service API key (gocars-api → gocars-auth, outgoing calls)
AUTH_API_KEY=

# External APIs
X_RAPIDAPI_KEY=
X_RAPIDAPI_HOST=https://rapidapi.com/
OPENAI_API_KEY=

# Garage API
GARAGE_HOST=
GARAGE_KEY=

# Monitoring
SENTRY_DSN=https://sentry.io/
